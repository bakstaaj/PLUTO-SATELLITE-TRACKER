# Copy this file to .pluto.env and fill in PLUTO_PASS locally.
# Do not commit .pluto.env.

# Pluto Plus firmware fallback Ethernet address is usually 192.168.3.1.
# USB Ethernet management may still be available at 192.168.2.1.
PLUTO_IP=192.168.3.1
PLUTO_USER=root
PLUTO_PASS=

# Small executable/web/config footprint on QSPI JFFS2.
PLUTO_DEPLOY_DIR=/mnt/jffs2/pluto_sat_tracker

# Larger satellite catalogs, pass caches, and logs on the Micro SD card.
PLUTO_SD_ROOT=/media/mmcblk0p1/pluto_sat_tracker

# Reuse the proven ADS-B Tracker v0.39 cross-build image by default.
PLUTO_CROSS_IMAGE=pluto-adsb-tracker-cross:v0.39
